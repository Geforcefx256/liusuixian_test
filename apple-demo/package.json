{
  "name": "apple-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "clean:all": "node scripts/clean-dist.mjs --with-node-modules",
    "reinstall": "pnpm run clean:all && pnpm install",
    "logs:skill-retention": "node scripts/find-skill-retention.mjs",
    "web": "pnpm run dev:web",
    "web-backend": "pnpm run dev:web-backend",
    "agent-backend": "pnpm run dev:agent-backend",
    "api": "pnpm run dev:api",
    "dev:web": "pnpm --filter @apple-demo/web dev",
    "dev:web-backend": "pnpm --filter @apple-demo/web-backend dev",
    "dev:agent-backend": "pnpm --filter @apple-demo/agent-backend dev",
    "dev:api": "pnpm --parallel --filter @apple-demo/web-backend --filter @apple-demo/agent-backend run dev",
    "dev:all": "node scripts/kill-port.mjs && pnpm --parallel --filter @apple-demo/web --filter @apple-demo/web-backend --filter @apple-demo/agent-backend run dev",
    "build:shared": "pnpm --filter @apple-demo/shared run build",
    "build:web": "pnpm --filter @apple-demo/web run clean && pnpm --filter @apple-demo/web run build",
    "build:web-backend": "pnpm --filter @apple-demo/web-backend run clean && pnpm --filter @apple-demo/web-backend run build && node scripts/assemble-web-backend.mjs",
    "build:agent-backend": "pnpm --filter @apple-demo/agent-backend run clean && pnpm --filter @apple-demo/agent-backend run build && node scripts/build-agent-dist.mjs",
    "build:all": "node scripts/clean-dist.mjs && pnpm run build:shared && pnpm run build:web && pnpm run build:web-backend && pnpm run build:agent-backend && node scripts/assemble-root-dist.mjs",
    "build": "pnpm run build:all",
    "test": "pnpm -r run test",
    "type-check": "pnpm -r run type-check"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/cors": "^2.8.17",
      "@types/express": "^4.17.21",
      "@types/morgan": "1.9.2",
      "@types/multer": "1.4.7",
      "@types/node": "^25.5.0",
      "@types/uuid": "^10.0.0",
      "@vitejs/plugin-vue": "^5.2.1",
      "@vue/compiler-sfc": "3.5.29",
      "@vue/test-utils": "^2.4.6",
      "axios": "^1.13.6",
      "chai": "5.2.0",
      "check-error": "2.1.1",
      "cors": "^2.8.5",
      "express": "^4.21.0",
      "get-tsconfig": "4.13.6",
      "morgan": "1.10.1",
      "multer": "^2.1.1",
      "sql.js": "1.14.0",
      "tsx": "^4.19.0",
      "typescript": "^5.9.3",
      "uuid": "^10.0.0",
      "vite": "^5.4.10",
      "vitest": "^2.1.9",
      "vue": "3.5.29",
      "vue-tsc": "2.2.8",
      "zod": "^3.25.76"
    }
  }
}
