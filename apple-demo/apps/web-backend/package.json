{
  "name": "@apple-demo/web-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "assemble": "node scripts/copy-runtime-files.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@apple-demo/shared": "workspace:*",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "morgan": "1.10.1",
    "sql.js": "1.14.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "1.9.2",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
